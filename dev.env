#This set of environment variables is intended for use with distro development.
#This configuration is not suitable for a production environment.
#At minimum, a production environment should use the default docker compose definition to limit port access.

#These variables enable the debug and mysql ports
COMPOSE_FILE="compose.yaml:compose.override.yaml"
MYSQL_PORT=3306
TOMCAT_DEBUG_PORT=1044

#The following variables should be adjusted for your specific instance needs.
TOMCAT_HTTP_PORT=8080
PIH_CONFIG="haiti,haiti-central,haiti-local-idgen"
SERVICE_NAME="openmrs-distro-zl"
OPENMRS_IMAGE_TAG="latest" 